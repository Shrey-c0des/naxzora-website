<%- include('partials/header') %>

<!-- Page Banner -->
<section class="page-banner text-center" style="padding-bottom: var(--space-4);">
    <div class="container" style="position: relative; z-index: 1;">
        <span class="pill-badge pill-badge-light hero-reveal">About Our Company</span>
        <h1 class="hero-reveal delay-1" style="font-size: 3.2rem;">Welcome to NAXZORA</h1>
        <p class="hero-reveal delay-2" style="text-transform: uppercase; letter-spacing: 3px; font-size: 0.9rem;">Bathrooms Made Perfect</p>
    </div>
</section>

<!-- Dark Product Showcase — Like Probath -->
<section style="background: #0a0a0a; text-align: center;">
    <div style="max-width: 1000px; margin: 0 auto;">
        <img src="/images/product_showcase.png" alt="NAXZORA Premium Product Showcase" class="reveal-scale" style="width: 100%; display: block;">
    </div>
</section>

<!-- Our Story Section -->
<section class="section" style="background: #fff; padding: var(--space-12) 0;">
    <div class="container">
        <div class="grid-2" style="gap: var(--space-8);">
            <!-- Left: Heading + Image -->
            <div>
                <p class="reveal" style="text-transform: uppercase; letter-spacing: 3px; font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Our Story</p>
                <h2 class="reveal delay-1" style="font-size: 2.8rem; line-height: 1.15; margin-bottom: var(--space-4);">Fixtures that Flow<br>with Imagination</h2>
                
                <!-- Luxury overlay image -->
                <div class="reveal-scale delay-2" style="position: relative; margin-top: var(--space-4);">
                    <div style="background: linear-gradient(135deg, var(--primary-hover), var(--primary)); border-radius: var(--radius-md); padding: var(--space-6) var(--space-4); text-align: center; color: #fff;">
                        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 0.5rem; color: rgba(255,255,255,0.7);">The Art of Flowing</p>
                        <h3 style="font-family: var(--font-heading); font-size: 2.5rem; color: #fff; letter-spacing: 4px; font-weight: 400; margin-bottom: 0.5rem;">LUXURY</h3>
                        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 3px; color: rgba(255,255,255,0.7);">In Every Drop</p>
                    </div>
                </div>
            </div>

            <!-- Right: Description + Link -->
            <div style="display: flex; flex-direction: column; justify-content: center;">
                <a href="/products" class="reveal" style="display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600; text-decoration: underline; text-underline-offset: 4px; margin-bottom: var(--space-6); align-self: flex-end;">Explore Our Products <i data-lucide="arrow-right" style="width: 16px;"></i></a>
                
                <p class="reveal delay-1" style="color: var(--text-secondary); line-height: 1.9; margin-bottom: var(--space-4);">
                    NAXZORA is dedicated to revolutionizing the way people experience and interact with their bathroom spaces. Our grand ambition is to innovate and enhance bathroom environments through cutting-edge technologies and thoughtful design solutions.
                </p>
                <p class="reveal delay-2" style="color: var(--text-secondary); line-height: 1.9;">
                    We aim to elevate comfort, convenience and luxury in every aspect of bathroom functionality and accessories. By continually pushing the boundaries of what's possible in bathroom design, NAXZORA strives to create products that inspire relaxation, efficiency, and a sense of well-being for all our customers.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Comfort Section -->
<section class="section" style="background: #fff; padding: var(--space-12) 0;">
    <div class="container">
        <div class="grid-2" style="gap: var(--space-8);">
            <div>
                <h2 class="reveal" style="font-size: 3rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: var(--space-2);">Comfort</h2>
                <div class="section-divider reveal delay-1" style="margin: 0 0 var(--space-4);"></div>
            </div>
            <div>
                <h3 class="reveal" style="font-size: 1.2rem; margin-bottom: var(--space-2);">Elegance in Every Turn</h3>
                <p class="reveal delay-1" style="color: var(--text-secondary); line-height: 1.9;">
                    At NAXZORA, our products exemplify a harmonious blend of innovative design and sophisticated elegance. Each piece is meticulously crafted to deliver exceptional functionality while exuding an air of luxury. Our commitment to superior quality ensures that every NAXZORA product stands out as a beacon of refined aesthetics and lasting durability, making it the perfect choice for those who seek both style and substance in their bathroom fixtures.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Convenience — Parallax Dark Section -->
<section class="parallax-section">
    <div class="container text-center" style="padding: var(--space-12) 0;">
        <h2 class="reveal" style="font-size: 3.5rem; color: #fff; text-transform: uppercase; letter-spacing: 4px; margin-bottom: var(--space-4);">Convenience</h2>
        <p class="reveal delay-1" style="color: rgba(255,255,255,0.75); max-width: 800px; margin: 0 auto; line-height: 1.9; font-size: 1.05rem;">
            We prioritize convenience in every product we design. Our innovative solutions are crafted to simplify installation and maintenance, offering seamless integration into any bathroom setting. With user-friendly features and intuitive design, NAXZORA ensures that our customers enjoy a hassle-free experience, combining practicality with luxury to meet the highest standards of modern living.
        </p>
    </div>
</section>

<!-- Quality Section -->
<section class="section" style="background: #fff; padding: var(--space-12) 0;">
    <div class="container">
        <div class="grid-2" style="gap: var(--space-8);">
            <!-- Left: Stacked images -->
            <div class="reveal-scale" style="position: relative; min-height: 400px;">
                <div style="position: absolute; top: 0; left: 0; width: 55%; height: 60%; background: repeating-conic-gradient(var(--primary-hover) 0% 25%, var(--primary) 0% 50%) 0 0 / 20px 20px; border-radius: var(--radius-md); opacity: 0.15;"></div>
                <div style="position: absolute; bottom: 0; left: 15%; width: 70%; background: linear-gradient(135deg, var(--accent), var(--primary)); border-radius: var(--radius-md); padding: var(--space-6) var(--space-4); text-align: center; color: #fff; box-shadow: 0 20px 40px rgba(0,91,105,0.2);">
                    <p style="font-family: var(--font-heading); font-size: 1.3rem; letter-spacing: 2px; font-weight: 400; text-transform: uppercase;">Innovative Faucets,<br>Infinite Possibilities</p>
                </div>
            </div>

            <!-- Right: Text -->
            <div style="display: flex; flex-direction: column; justify-content: center;">
                <h2 class="reveal" style="font-size: 2.8rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: var(--space-3);">Sustainability</h2>
                <p class="reveal delay-1" style="color: var(--text-secondary); line-height: 1.9; margin-bottom: var(--space-4);">
                    Sustainability is at the core of our products. We are dedicated to creating environmentally friendly bathroom solutions that minimize resource consumption and reduce waste. Our products are designed with eco-conscious materials and innovative technologies to ensure long-lasting performance and a smaller ecological footprint.
                </p>
                <p class="reveal delay-2" style="color: var(--text-secondary); line-height: 1.9; margin-bottom: var(--space-6);">
                    NAXZORA's commitment to sustainability reflects our mission to provide luxurious, high-quality products that are kind to the planet, ensuring a greener future for all.
                </p>
                <div class="reveal delay-3">
                    <a href="/contact" class="btn">Contact Us</a>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
