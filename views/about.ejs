<%- include('partials/header') %>

<!-- Page Banner -->
<section class="page-banner text-center">
    <div class="container" style="position: relative; z-index: 1;">
        <span class="pill-badge pill-badge-light hero-reveal">About Our Company</span>
        <h1 class="hero-reveal delay-1">Our Story</h1>
        <p class="hero-reveal delay-2">Dedicated to delivering precision, quality, and luxury in every fitting.</p>
    </div>
</section>

<section class="section section-cyan">
    <div class="container">
        <div class="grid-2" style="margin-bottom: var(--space-12);">
            <div class="animate-on-scroll">
                <img src="/images/panda.jpeg" alt="NAXZORA Panda Mascot" style="border-radius: var(--radius-xl); width: 100%; height: auto; max-height: 500px; object-fit: contain; background-color: #fff; box-shadow: 0 20px 40px rgba(0,91,105,0.1); border: 3px solid rgba(0,91,105,0.1);">
            </div>
            <div class="animate-on-scroll" style="padding-left: var(--space-4);">
                <p style="color: var(--highlight); text-transform: uppercase; letter-spacing: 3px; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem;">Our Vision</p>
                <h2 style="font-size: 2.5rem; color: var(--primary);">The NAXZORA Vision</h2>
                <div class="section-divider" style="margin: 0 0 var(--space-3);"></div>
                <p style="color: var(--text-secondary); margin-bottom: var(--space-3); line-height: 1.9;">Founded with a passion for excellence, NAXZORA has quickly become a trusted name in premium bathroom fittings and sanitary hardware. We believe that hardware shouldn't just be functional—it should be a statement of luxury and refined taste.</p>
                <p style="color: var(--text-secondary); line-height: 1.9;">Every product that bears the NAXZORA name undergoes rigorous testing to ensure it meets our strict standards for durability, flow rate, and finish resilience.</p>
            </div>
        </div>

        <div class="grid-2" style="margin-bottom: var(--space-12);">
            <div class="animate-on-scroll" style="padding-right: var(--space-4); order: 2;">
                <p style="color: var(--highlight); text-transform: uppercase; letter-spacing: 3px; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem;">Our Promise</p>
                <h2 style="font-size: 2.5rem; color: var(--primary);">Uncompromising Quality</h2>
                <div class="section-divider" style="margin: 0 0 var(--space-3);"></div>
                <ul style="color: var(--text-secondary); list-style: none;">
                    <li style="margin-bottom: var(--space-3); display: flex; gap: 1rem; background: rgba(0,91,105,0.03); padding: 1rem; border-radius: var(--radius-md); border: 1px solid rgba(0,91,105,0.06);">
                        <i data-lucide="check-circle" style="color: var(--highlight); min-width: 24px;"></i>
                        <div>
                            <strong style="color: var(--text-primary);">Premium Materials</strong>
                            <p>We use only high-grade brass, CPVC, and 304 stainless steel to prevent corrosion and ensure longevity.</p>
                        </div>
                    </li>
                    <li style="margin-bottom: var(--space-3); display: flex; gap: 1rem; background: rgba(0,91,105,0.03); padding: 1rem; border-radius: var(--radius-md); border: 1px solid rgba(0,91,105,0.06);">
                        <i data-lucide="check-circle" style="color: var(--highlight); min-width: 24px;"></i>
                        <div>
                            <strong style="color: var(--text-primary);">Advanced Mechanisms</strong>
                            <p>Equipped with imported ceramic disc cartridges for smooth, drip-free operation up to 500,000 cycles.</p>
                        </div>
                    </li>
                    <li style="display: flex; gap: 1rem; background: rgba(0,91,105,0.03); padding: 1rem; border-radius: var(--radius-md); border: 1px solid rgba(0,91,105,0.06);">
                        <i data-lucide="check-circle" style="color: var(--highlight); min-width: 24px;"></i>
                        <div>
                            <strong style="color: var(--text-primary);">Flawless Finish</strong>
                            <p>Multi-layer plating process for a rich, deep finish that resists tarnishing and scratching.</p>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="animate-on-scroll" style="order: 1;">
                <img src="https://placehold.co/800x600/eaf7f8/005b69?text=Quality+Testing" alt="Quality Control" style="border-radius: var(--radius-lg); width: 100%; box-shadow: 0 20px 40px rgba(0,91,105,0.1);">
            </div>
        </div>
    </div>
</section>

<section class="section section-cyan-dark text-center" style="padding: var(--space-8) 0;">
    <div class="container animate-on-scroll">
        <h2 style="font-size: 2.5rem; margin-bottom: var(--space-4);">Ready to upgrade your space?</h2>
        <p style="color: rgba(255,255,255,0.7); margin-bottom: var(--space-4); max-width: 500px; margin-left: auto; margin-right: auto;">Explore our full range of premium products or get in touch for custom orders.</p>
        <a href="/products" class="btn" style="background: linear-gradient(135deg, var(--highlight), #e8922c); border-color: var(--highlight);">View Our Products</a>
    </div>
</section>

<%- include('partials/footer') %>
