<%- include('partials/header') %>

<div style="padding-top: 100px;">
    <div class="container">
        <!-- Header -->
        <div class="text-center animate-on-scroll" style="margin-bottom: var(--space-8);">
            <h1 style="font-size: 3rem; margin-bottom: var(--space-2);">Our Story</h1>
            <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Dedicated to delivering precision, quality, and luxury in every fitting.</p>
        </div>

        <div class="grid-2" style="margin-bottom: var(--space-12);">
            <div class="animate-on-scroll">
                <img src="/images/panda.jpeg" alt="NAXZORA Panda Mascot" style="border-radius: var(--radius-lg); width: 100%; height: auto; max-height: 500px; object-fit: contain; background-color: #fff; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 2px solid var(--border);">
            </div>
            <div class="animate-on-scroll" style="padding-left: var(--space-4);">
                <h2 style="font-size: 2.5rem; color: var(--primary);">The NAXZORA Vision</h2>
                <p style="color: var(--text-secondary); margin-bottom: var(--space-3);">Founded with a passion for excellence, NAXZORA has quickly become a trusted name in premium bathroom fittings and sanitary hardware. We believe that hardware shouldn't just be functional—it should be a statement of luxury and refined taste.</p>
                <p style="color: var(--text-secondary);">Every product that bears the NAXZORA name undergoes rigorous testing to ensure it meets our strict standards for durability, flow rate, and finish resilience.</p>
            </div>
        </div>

        <div class="grid-2" style="margin-bottom: var(--space-12);">
            <div class="animate-on-scroll" style="padding-right: var(--space-4); order: 2;">
                <h2 style="font-size: 2.5rem; color: var(--primary);">Uncompromising Quality</h2>
                <ul style="color: var(--text-secondary); list-style: none;">
                    <li style="margin-bottom: var(--space-2); display: flex; gap: 1rem;">
                        <i data-lucide="check-circle" style="color: var(--highlight);"></i>
                        <div>
                            <strong style="color: var(--text-primary);">Premium Materials</strong>
                            <p>We use only high-grade brass, CPVC, and 304 stainless steel to prevent corrosion and ensure longevity.</p>
                        </div>
                    </li>
                    <li style="margin-bottom: var(--space-2); display: flex; gap: 1rem;">
                        <i data-lucide="check-circle" style="color: var(--highlight);"></i>
                        <div>
                            <strong style="color: var(--text-primary);">Advanced Mechanisms</strong>
                            <p>Equipped with imported ceramic disc cartridges for smooth, drip-free operation up to 500,000 cycles.</p>
                        </div>
                    </li>
                    <li style="display: flex; gap: 1rem;">
                        <i data-lucide="check-circle" style="color: var(--highlight);"></i>
                        <div>
                            <strong style="color: var(--text-primary);">Flawless Finish</strong>
                            <p>Multi-layer plating process for a rich, deep finish that resists tarnishing and scratching.</p>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="animate-on-scroll" style="order: 1;">
                <img src="https://placehold.co/800x600/f8fafc/005b69?text=Quality+Testing" alt="Quality Control" style="border-radius: var(--radius-md); width: 100%;">
            </div>
        </div>
    </div>
</div>

<section class="section" style="background-color: var(--border-light); text-center">
    <div class="container animate-on-scroll text-center">
        <h2 style="font-size: 2.5rem; margin-bottom: var(--space-4);">Ready to upgrade your space?</h2>
        <a href="/products" class="btn">View Our Products</a>
    </div>
</section>

<%- include('partials/footer') %>
