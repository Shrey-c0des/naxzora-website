<%- include('partials/header') %>

<!-- Page Banner -->
<section class="page-banner">
    <div class="container" style="position: relative; z-index: 1;">
        <div class="hero-reveal" style="margin-bottom: var(--space-2); font-size: 0.85rem;">
            <a href="/products" style="color: rgba(255,255,255,0.7);">Products</a>
            <span style="color: rgba(255,255,255,0.4); margin: 0 0.5rem;">›</span>
            <a href="/products?category=<%= product.category_slug %>" style="color: rgba(255,255,255,0.7);"><%= product.category_name %></a>
            <span style="color: rgba(255,255,255,0.4); margin: 0 0.5rem;">›</span>
            <span style="color: #fff;"><%= product.name %></span>
        </div>
        <h1 class="hero-reveal delay-1" style="font-size: 2.5rem;"><%= product.name %></h1>
    </div>
</section>

<section class="section section-cyan">
    <div class="container">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: var(--space-8);">
            
            <!-- Gallery -->
            <div class="animate-on-scroll">
                <div style="border-radius: var(--radius-lg); overflow: hidden; background: #fff; border: 1px solid rgba(0,91,105,0.08); margin-bottom: 1rem; box-shadow: 0 10px 30px rgba(0,91,105,0.06);">
                    <img id="main-product-image" src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/800x800/eaf7f8/005b69?text=NAXZORA'" style="width: 100%; object-fit: cover;">
                </div>
                <!-- Thumbnails -->
                <div style="display: flex; gap: 0.8rem; overflow-x: auto;">
                    <% product.gallery.forEach(imgUrl => { %>
                        <img src="<%= imgUrl %>" class="thumbnail" onclick="document.getElementById('main-product-image').src = this.src" onerror="this.src='https://placehold.co/200x200/eaf7f8/005b69?text=Thumb'" style="width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-sm); cursor: pointer; border: 2px solid var(--border); transition: all 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.05);" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
                    <% }) %>
                </div>
            </div>

            <!-- Details -->
            <div class="animate-on-scroll">
                <span style="font-size: 0.75rem; color: var(--highlight); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;"><%= product.category_name %></span>
                <h1 style="font-size: 2.5rem; margin-bottom: var(--space-1); margin-top: 0.5rem;"><%= product.name %></h1>
                <div class="section-divider" style="margin: 0 0 var(--space-3);"></div>
                
                <p style="color: var(--text-secondary); margin-bottom: var(--space-4); font-size: 1.05rem; line-height: 1.9;">
                    <%= product.description %>
                </p>

                <div style="background: #fff; border: 1px solid rgba(0,91,105,0.08); border-radius: var(--radius-md); padding: var(--space-3); margin-bottom: var(--space-4); box-shadow: 0 4px 15px rgba(0,91,105,0.04);">
                    <h3 style="margin-bottom: var(--space-2); font-size: 1.1rem;"><i data-lucide="settings" style="width: 18px; display: inline; vertical-align: middle; color: var(--highlight);"></i> Specifications</h3>
                    <div style="display: grid; grid-template-columns: 100px 1fr; gap: 0.5rem;">
                        <span style="color: var(--text-secondary); font-size: 0.9rem;">Material:</span>
                        <span style="font-weight: 500;"><%= product.material %></span>
                        <span style="color: var(--text-secondary); font-size: 0.9rem;">Finish:</span>
                        <span style="font-weight: 500;"><%= product.finish %></span>
                    </div>
                </div>

                <div style="margin-bottom: var(--space-6);">
                    <h3 style="margin-bottom: var(--space-2); font-size: 1.1rem;"><i data-lucide="star" style="width: 18px; display: inline; vertical-align: middle; color: var(--highlight);"></i> Key Features</h3>
                    <ul style="list-style: none; color: var(--text-secondary);">
                        <% product.features.forEach(feature => { %>
                            <li style="margin-bottom: 0.6rem; display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0.8rem; background: var(--primary-light); border-radius: var(--radius-sm);">
                                <i data-lucide="check" style="color: var(--primary); width: 16px; min-width: 16px;"></i>
                                <span style="font-size: 0.95rem;"><%= feature %></span>
                            </li>
                        <% }) %>
                    </ul>
                </div>

                <a href="/contact?product=<%= product.name %>" class="btn" style="width: 100%; text-align: center; padding: 1rem;">
                    <i data-lucide="message-circle" style="width: 18px; display: inline; vertical-align: middle; margin-right: 0.5rem;"></i>
                    Inquire About This Product
                </a>
            </div>
        </div>
    </div>
</section>

<% if (relatedProducts.length > 0) { %>
<section class="section" style="background: linear-gradient(135deg, #f1f5f9 0%, var(--cyan-bg) 100%);">
    <div class="container animate-on-scroll">
        <div class="text-center" style="margin-bottom: var(--space-6);">
            <p style="color: var(--highlight); text-transform: uppercase; letter-spacing: 3px; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem;">You May Also Like</p>
            <h2 style="font-size: 2rem;">Related Products</h2>
            <div class="section-divider"></div>
        </div>
        <div class="grid">
            <% relatedProducts.forEach(product => { %>
                <a href="/products/<%= product.slug %>" class="card">
                    <div class="card-img">
                        <img src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/600x600/eaf7f8/005b69?text=NAXZORA'">
                    </div>
                    <div class="card-content">
                        <span style="font-size: 0.75rem; color: var(--highlight); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600;"><%= product.category_name %></span>
                        <h3 class="card-title" style="margin-top: 0.5rem;"><%= product.name %></h3>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<%- include('partials/footer') %>
