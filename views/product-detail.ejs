<%- include('partials/header') %>

<div style="padding-top: 100px;">
    <div class="container" style="padding-bottom: var(--space-12);">
        
        <!-- Breadcrumbs -->
        <div class="animate-on-scroll" style="margin-bottom: var(--space-4); color: var(--text-secondary); font-size: 0.9rem;">
            <a href="/products">Products</a> / 
            <a href="/products?category=<%= product.category_slug %>"><%= product.category_name %></a> / 
            <span style="color: var(--text-primary);"><%= product.name %></span>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: var(--space-8);">
            
            <!-- Gallery -->
            <div class="animate-on-scroll">
                <div style="border-radius: var(--radius-md); overflow: hidden; background: var(--bg-card); border: 1px solid var(--border); margin-bottom: 1rem;">
                    <img id="main-product-image" src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/800x800/f8fafc/005b69?text=NAXZORA'" style="width: 100%; object-fit: cover;">
                </div>
                <!-- Thumbnails -->
                <div style="display: flex; gap: 1rem; overflow-x: auto;">
                    <% product.gallery.forEach(imgUrl => { %>
                        <img src="<%= imgUrl %>" class="thumbnail" onclick="document.getElementById('main-product-image').src = this.src" onerror="this.src='https://placehold.co/200x200/f8fafc/005b69?text=Thumb'" style="width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-sm); cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s;">
                    <% }) %>
                </div>
            </div>

            <!-- Details -->
            <div class="animate-on-scroll">
                <h1 style="font-size: 2.5rem; margin-bottom: var(--space-1);"><%= product.name %></h1>
                <p style="color: var(--highlight); margin-bottom: var(--space-3); font-size: 1.1rem;"><%= product.finish %></p>
                
                <p style="color: var(--text-secondary); margin-bottom: var(--space-4); font-size: 1.1rem; line-height: 1.8;">
                    <%= product.description %>
                </p>

                <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-3); margin-bottom: var(--space-4);">
                    <h3 style="margin-bottom: var(--space-2); font-size: 1.2rem;">Specifications</h3>
                    <div style="display: grid; grid-template-columns: 100px 1fr; gap: 0.5rem; margin-bottom: 1rem;">
                        <span style="color: var(--text-secondary);">Material:</span>
                        <span><%= product.material %></span>
                        <span style="color: var(--text-secondary);">Finish:</span>
                        <span><%= product.finish %></span>
                    </div>
                </div>

                <div style="margin-bottom: var(--space-6);">
                    <h3 style="margin-bottom: var(--space-2); font-size: 1.2rem;">Key Features</h3>
                    <ul style="list-style: none; color: var(--text-secondary);">
                        <% product.features.forEach(feature => { %>
                            <li style="margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                                <i data-lucide="check" style="color: var(--highlight); width: 16px;"></i>
                                <%= feature %>
                            </li>
                        <% }) %>
                    </ul>
                </div>

                <a href="/contact?product=<%= product.name %>" class="btn" style="width: 100%; text-align: center;">Inquire About This Product</a>
            </div>
        </div>
    </div>
</div>

<% if (relatedProducts.length > 0) { %>
<section class="section" style="background-color: var(--border-light);">
    <div class="container animate-on-scroll">
        <h2 style="font-size: 2rem; margin-bottom: var(--space-4);">Related Products</h2>
        <div class="grid">
            <% relatedProducts.forEach(product => { %>
                <a href="/products/<%= product.slug %>" class="card" style="background: var(--bg-dark);">
                    <div class="card-img">
                        <img src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/600x600/f8fafc/005b69?text=NAXZORA'">
                    </div>
                    <div class="card-content">
                        <span style="font-size: 0.8rem; color: var(--highlight); text-transform: uppercase; letter-spacing: 1px;"><%= product.category_name %></span>
                        <h3 class="card-title" style="margin-top: 0.5rem;"><%= product.name %></h3>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<%- include('partials/footer') %>
