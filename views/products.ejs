<%- include('partials/header') %>

<!-- Page Banner -->
<section class="page-banner text-center">
    <div class="container" style="position: relative; z-index: 1;">
        <span class="pill-badge pill-badge-light hero-reveal">Our Collection</span>
        <h1 class="hero-reveal delay-1"><%= activeCategory ? activeCategory.name : 'All Products' %></h1>
        <% if (activeCategory) { %>
            <p class="hero-reveal delay-2"><%= activeCategory.description %></p>
        <% } else { %>
            <p class="hero-reveal delay-2">Browse our complete collection of premium bathroom fittings, showers, pipes, and accessories.</p>
        <% } %>
    </div>
</section>

<section class="section section-cyan">
    <div class="container">
        <!-- Categories Filter -->
        <div class="animate-on-scroll" style="margin-bottom: var(--space-8); display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center;">
            <a href="/products" class="btn <%= !activeCategorySlug ? '' : 'btn-outline' %>">All</a>
            <% categories.forEach(cat => { %>
                <a href="/products?category=<%= cat.slug %>" class="btn <%= activeCategorySlug === cat.slug ? '' : 'btn-outline' %>"><%= cat.name %></a>
            <% }) %>
        </div>

        <!-- Products Grid -->
        <div class="grid animate-on-scroll">
            <% if (products.length > 0) { %>
                <% products.forEach(product => { %>
                    <a href="/products/<%= product.slug %>" class="card">
                        <div class="card-img">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/600x600/eaf7f8/005b69?text=NAXZORA'">
                        </div>
                        <div class="card-content">
                            <span style="font-size: 0.75rem; color: var(--highlight); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600;"><%= product.category_name %></span>
                            <h3 class="card-title" style="margin-top: 0.5rem;"><%= product.name %></h3>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: var(--space-8) 0; color: var(--text-secondary);">
                    <i data-lucide="package" style="width: 48px; height: 48px; color: var(--accent); margin-bottom: 1rem;"></i>
                    <h3>No products found in this category.</h3>
                    <p style="margin-top: 0.5rem;">Check back soon or browse all products.</p>
                </div>
            <% } %>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
