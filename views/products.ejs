<%- include('partials/header') %>

<div style="padding-top: 100px;">
    <div class="container">
        <div class="text-center animate-on-scroll" style="margin-bottom: var(--space-8);">
            <h1 style="font-size: 3rem; margin-bottom: var(--space-2);"><%= activeCategory ? activeCategory.name : 'All Products' %></h1>
            <% if (activeCategory) { %>
                <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;"><%= activeCategory.description %></p>
            <% } else { %>
                <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Browse our complete collection of premium bathroom fittings, showers, pipes, and accessories.</p>
            <% } %>
        </div>

        <!-- Categories Filter -->
        <div class="animate-on-scroll" style="margin-bottom: var(--space-8); display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center;">
            <a href="/products" class="btn <%= !activeCategorySlug ? '' : 'btn-outline' %>">All</a>
            <% categories.forEach(cat => { %>
                <a href="/products?category=<%= cat.slug %>" class="btn <%= activeCategorySlug === cat.slug ? '' : 'btn-outline' %>"><%= cat.name %></a>
            <% }) %>
        </div>

        <!-- Products Grid -->
        <div class="grid animate-on-scroll">
            <% if (products.length > 0) { %>
                <% products.forEach(product => { %>
                    <a href="/products/<%= product.slug %>" class="card">
                        <div class="card-img">
                            <img src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/600x600/f8fafc/005b69?text=NAXZORA'">
                        </div>
                        <div class="card-content">
                            <span style="font-size: 0.8rem; color: var(--highlight); text-transform: uppercase; letter-spacing: 1px;"><%= product.category_name %></span>
                            <h3 class="card-title" style="margin-top: 0.5rem;"><%= product.name %></h3>
                            <p class="card-desc"><%= product.finish %></p>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: var(--space-8) 0; color: var(--text-secondary);">
                    <h3>No products found in this category.</h3>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
