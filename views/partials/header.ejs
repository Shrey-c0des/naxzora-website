<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'NAXZORA | Premium Bathroom Fittings & Sanitary Hardware' %></title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="NAXZORA offers precision-engineered, luxury bathroom fittings, faucets, and sanitary hardware. Elevate your living space with our durable and elegant collections.">
    <meta name="keywords" content="NAXZORA, bathroom fittings, faucets, taps, sanitary hardware, luxury bathroom, home fittings, Rajkot hardware, premium faucets">
    <meta name="author" content="NAXZORA">
    <meta name="robots" content="index, follow">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://naxzora-website.onrender.com/">
    <meta property="og:title" content="NAXZORA | Premium Bathroom Fittings">
    <meta property="og:description" content="Precision Engineering for Modern Living. Explore our luxury collection of bathroom and sanitary hardware.">
    <meta property="og:image" content="/images/panda.jpeg">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content="NAXZORA | Premium Bathroom Fittings">
    <meta property="twitter:description" content="Precision Engineering for Modern Living. Explore our luxury collection.">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/panda_face.png">
    
    <!-- Canonical Link -->
    <link rel="canonical" href="https://naxzora-website.onrender.com/">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<nav class="navbar" id="navbar">
    <div class="nav-overlay" id="nav-overlay"></div>
    <div class="container nav-container" style="position: relative;">
        <!-- Logo on LEFT side -->
        <a href="/" class="logo">
            <img src="/images/logo_left.png" alt="NAXZORA Logo">
        </a>

        <button class="mobile-menu-btn" id="mobile-menu-btn">
            <i data-lucide="menu"></i>
        </button>

        <ul class="nav-links" id="nav-links">
            <li><a href="/" class="<%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'active' : '' %>">Home</a></li>
            <li><a href="/about" class="<%= typeof currentPage !== 'undefined' && currentPage === 'about' ? 'active' : '' %>">About</a></li>
            <li><a href="/products" class="<%= typeof currentPage !== 'undefined' && currentPage === 'products' ? 'active' : '' %>">Products</a></li>
            <li><a href="/contact" class="<%= typeof currentPage !== 'undefined' && currentPage === 'contact' ? 'active' : '' %>">Contact</a></li>
            <li><button class="btn" id="openBrochureModal" style="padding: 0.5rem 1rem; font-size: 0.75rem;">Download Brochure</button></li>
        </ul>

        <!-- Waves on RIGHT side -->
        <img src="/images/logo_waves.png" alt="NAXZORA Waves" class="nav-waves">
    </div>
</nav>

<!-- Brochure Modal -->
<div id="brochureModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" id="closeBrochureModal">&times;</span>
        <h2 style="margin-bottom: 1rem; color: var(--primary);">Download Brochure</h2>
        <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">Please provide your details to download the latest NAXZORA product brochure.</p>
        
        <form action="/brochure" method="POST" id="brochureForm">
            <div style="margin-bottom: 1rem;">
                <label for="b_name" style="display: block; margin-bottom: 0.3rem; color: var(--text-secondary); font-size: 0.9rem;">Name *</label>
                <input type="text" id="b_name" name="name" required class="form-input">
            </div>
            <div style="margin-bottom: 1rem;">
                <label for="b_mobile" style="display: block; margin-bottom: 0.3rem; color: var(--text-secondary); font-size: 0.9rem;">Mobile Number *</label>
                <input type="tel" id="b_mobile" name="mobile" required class="form-input">
            </div>
            <div style="margin-bottom: 1rem;">
                <label for="b_email" style="display: block; margin-bottom: 0.3rem; color: var(--text-secondary); font-size: 0.9rem;">Email Address *</label>
                <input type="email" id="b_email" name="email" required class="form-input">
            </div>
            <div style="margin-bottom: 1.5rem;">
                <label for="b_city" style="display: block; margin-bottom: 0.3rem; color: var(--text-secondary); font-size: 0.9rem;">City *</label>
                <input type="text" id="b_city" name="city" required class="form-input">
            </div>
            <button type="submit" class="btn" style="width: 100%;">Download Now</button>
        </form>
    </div>
</div>

<main>
