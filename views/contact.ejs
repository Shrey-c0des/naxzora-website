<%- include('partials/header') %>

<!-- Page Banner -->
<section class="page-banner text-center">
    <div class="container" style="position: relative; z-index: 1;">
        <span class="pill-badge pill-badge-light hero-reveal">Contact Us</span>
        <h1 class="hero-reveal delay-1" style="font-size: 2.8rem;">Say hello and let's start<br>working together.</h1>
        <p class="hero-reveal delay-2">Have a question about our products or want to place a bulk order? We're here to help.</p>
    </div>
</section>

<section class="section section-cyan">
    <div class="container">
        <div class="grid" style="align-items: start; gap: var(--space-8);">
            
            <!-- Contact Info -->
            <div class="animate-on-scroll">
                <div style="background: #fff; border: 1px solid rgba(0,91,105,0.08); border-radius: var(--radius-lg); padding: var(--space-4); box-shadow: 0 10px 30px rgba(0,91,105,0.06);">
                    <h2 style="font-size: 1.8rem; margin-bottom: var(--space-4);">Get in Touch</h2>
                    <div class="section-divider" style="margin: 0 0 var(--space-4);"></div>
                    
                    <div style="display: flex; gap: 1rem; margin-bottom: var(--space-3); padding: 1rem; background: var(--primary-light); border-radius: var(--radius-md);">
                        <i data-lucide="map-pin" style="color: var(--primary); margin-top: 4px; min-width: 20px;"></i>
                        <div>
                            <strong style="display: block; margin-bottom: 0.2rem; color: var(--primary);">Head Office</strong>
                            <p style="color: var(--text-secondary);">Survey No, 42, Plot No. 6, B/h, Hero Showroom,<br>Gondal Road, Vavdi, Dist. Rajkot, Gujarat - 360004</p>
                        </div>
                    </div>

                    <div style="display: flex; gap: 1rem; margin-bottom: var(--space-3); padding: 1rem; background: var(--primary-light); border-radius: var(--radius-md);">
                        <i data-lucide="phone" style="color: var(--primary); margin-top: 4px; min-width: 20px;"></i>
                        <div>
                            <strong style="display: block; margin-bottom: 0.2rem; color: var(--primary);">Phone</strong>
                            <p style="color: var(--text-secondary);">+91 79902 13618</p>
                        </div>
                    </div>

                    <div style="display: flex; gap: 1rem; margin-bottom: var(--space-4); padding: 1rem; background: var(--primary-light); border-radius: var(--radius-md);">
                        <i data-lucide="mail" style="color: var(--primary); margin-top: 4px; min-width: 20px;"></i>
                        <div>
                            <strong style="display: block; margin-bottom: 0.2rem; color: var(--primary);">Email</strong>
                            <p style="color: var(--text-secondary);">naxzorabathimpex@gmail.com</p>
                        </div>
                    </div>

                    <div style="background: rgba(0,91,105,0.03); padding: 1rem; border-radius: var(--radius-md); border: 1px solid rgba(0,91,105,0.06);">
                        <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;"><i data-lucide="clock" style="width: 18px; display: inline; vertical-align: middle; color: var(--highlight);"></i> Business Hours</h3>
                        <p style="color: var(--text-secondary);">Monday - Saturday: 9:00 AM - 6:00 PM<br>Sunday: Closed</p>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="animate-on-scroll">
                <% if (success) { %>
                    <div style="background: #fff; border: 1px solid rgba(0,91,105,0.08); padding: var(--space-6); border-radius: var(--radius-lg); text-align: center; box-shadow: 0 10px 30px rgba(0,91,105,0.06);">
                        <div style="width: 64px; height: 64px; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                            <i data-lucide="check-circle" style="color: var(--primary); width: 32px; height: 32px;"></i>
                        </div>
                        <h3 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 1.5rem;">Message Sent Successfully!</h3>
                        <p style="color: var(--text-secondary); margin-bottom: var(--space-4);">Thank you for contacting NAXZORA. Our team will get back to you within 24 hours.</p>
                        <a href="/" class="btn">Return Home</a>
                    </div>
                <% } else { %>
                    <form action="/contact" method="POST" style="background: #fff; border: 1px solid rgba(0,91,105,0.08); border-radius: var(--radius-lg); padding: var(--space-4); box-shadow: 0 10px 30px rgba(0,91,105,0.06);">
                        <h2 style="font-size: 1.5rem; margin-bottom: var(--space-3);">Send Us a Message</h2>
                        <div class="section-divider" style="margin: 0 0 var(--space-4);"></div>
                        
                        <div style="margin-bottom: 1.5rem;">
                            <label for="name" style="display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.9rem; font-weight: 500;">Full Name *</label>
                            <input type="text" id="name" name="name" required class="form-input">
                        </div>
                        
                        <div style="margin-bottom: 1.5rem;">
                            <label for="email" style="display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.9rem; font-weight: 500;">Email Address *</label>
                            <input type="email" id="email" name="email" required class="form-input">
                        </div>

                        <div style="margin-bottom: 1.5rem;">
                            <label for="phone" style="display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.9rem; font-weight: 500;">Phone Number (Optional)</label>
                            <input type="tel" id="phone" name="phone" class="form-input">
                        </div>

                        <div style="margin-bottom: 1.5rem;">
                            <label for="message" style="display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.9rem; font-weight: 500;">Your Message *</label>
                            <textarea id="message" name="message" rows="5" required class="form-input" style="resize: vertical;"></textarea>
                        </div>

                        <button type="submit" class="btn" style="width: 100%;">Send Message</button>
                    </form>
                <% } %>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
