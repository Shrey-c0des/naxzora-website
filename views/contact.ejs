<%- include('partials/header') %>

<!-- Page Banner -->
<section class="page-banner text-center">
    <div class="container" style="position: relative; z-index: 1;">
        <span class="pill-badge pill-badge-light hero-reveal">Contact Us</span>
        <h1 class="hero-reveal delay-1" style="font-size: 2.8rem;">Say hello and let's start<br>working together.</h1>
        <p class="hero-reveal delay-2">Have a question about our products or want to place a bulk order? We're here to help.</p>
    </div>
</section>

<!-- Contact Info Cards — Horizontal Row -->
<section class="section section-cyan">
    <div class="container">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-bottom: var(--space-8);" class="contact-info-grid">
            
            <!-- Call Us -->
            <div class="reveal delay-1" style="display: flex; align-items: flex-start; gap: 1rem;">
                <div style="width: 50px; height: 50px; min-width: 50px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="phone" style="color: #fff; width: 20px; height: 20px;"></i>
                </div>
                <div>
                    <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Call Us</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 0.5rem;">+91 79902 13618</p>
                    <a href="tel:+917990213618" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; text-decoration: underline; text-underline-offset: 3px;">Call Now</a>
                </div>
            </div>

            <!-- Address -->
            <div class="reveal delay-2" style="display: flex; align-items: flex-start; gap: 1rem;">
                <div style="width: 50px; height: 50px; min-width: 50px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="map-pin" style="color: #fff; width: 20px; height: 20px;"></i>
                </div>
                <div>
                    <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Address</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 0.5rem;">Survey No. 42, Plot No. 6,<br>B/h Hero Showroom, Gondal Road,<br>Vavdi, Rajkot, Gujarat – 360004</p>
                    <a href="https://maps.google.com/?q=Vavdi+Rajkot+Gujarat" target="_blank" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; text-decoration: underline; text-underline-offset: 3px;">See Map</a>
                </div>
            </div>

            <!-- Email -->
            <div class="reveal delay-3" style="display: flex; align-items: flex-start; gap: 1rem;">
                <div style="width: 50px; height: 50px; min-width: 50px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="mail" style="color: #fff; width: 20px; height: 20px;"></i>
                </div>
                <div>
                    <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Email</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 0.5rem;">naxzorabathimpex@gmail.com</p>
                    <a href="mailto:naxzorabathimpex@gmail.com" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; text-decoration: underline; text-underline-offset: 3px;">Say Hello</a>
                </div>
            </div>
        </div>

        <!-- Divider -->
        <hr class="reveal" style="border: none; border-top: 1px solid var(--border); margin-bottom: var(--space-8);">

        <!-- Contact Form — Horizontal Layout -->
        <% if (success) { %>
            <div class="reveal" style="text-align: center; padding: var(--space-8) 0;">
                <div style="width: 64px; height: 64px; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <i data-lucide="check-circle" style="color: var(--primary); width: 32px; height: 32px;"></i>
                </div>
                <h3 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 1.5rem;">Message Sent Successfully!</h3>
                <p style="color: var(--text-secondary); margin-bottom: var(--space-4);">Thank you for contacting NAXZORA. Our team will get back to you within 24 hours.</p>
                <a href="/" class="btn">Return Home</a>
            </div>
        <% } else { %>
            <form action="/contact" method="POST" class="reveal delay-1">
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-bottom: var(--space-4);" class="form-row-grid">
                    <div>
                        <label for="name" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem;">Name</label>
                        <input type="text" id="name" name="name" required class="form-input" placeholder="Enter your name">
                    </div>
                    <div>
                        <label for="phone" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem;">Phone Number</label>
                        <input type="tel" id="phone" name="phone" class="form-input" placeholder="Enter your Phone Number">
                    </div>
                    <div>
                        <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem;">Email</label>
                        <input type="email" id="email" name="email" required class="form-input" placeholder="Enter your email">
                    </div>
                </div>
                <div style="margin-bottom: var(--space-4);">
                    <label for="message" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem;">Message</label>
                    <textarea id="message" name="message" rows="5" required class="form-input" style="resize: vertical;" placeholder="Enter your message"></textarea>
                </div>
                <div style="text-align: right;">
                    <button type="submit" class="btn">Send Message</button>
                </div>
            </form>
        <% } %>
    </div>
</section>

<style>
    @media (max-width: 768px) {
        .contact-info-grid { grid-template-columns: 1fr !important; }
        .form-row-grid { grid-template-columns: 1fr !important; }
    }
</style>

<!-- Google Map -->
<section style="width: 100%; height: 450px; position: relative;">
    <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3691.5!2d70.75!3d22.27!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjLCsDE2JzEyLjAiTiA3MMKwNDUnMDAuMCJF!5e0!3m2!1sen!2sin!4v1600000000000!5m2!1sen!2sin&q=Survey+No+42+Plot+6+Gondal+Road+Vavdi+Rajkot+Gujarat+360004"
        width="100%" 
        height="100%" 
        style="border: 0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
    </iframe>
</section>

<%- include('partials/footer') %>
