<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="container">
        <div class="hero-content animate-on-scroll">
            <h1>Precision Engineering for Modern Living.</h1>
            <p>Elevate your space with NAXZORA's premium bathroom fittings and sanitary hardware. Crafted for durability, designed for elegance.</p>
            <a href="/products" class="btn">Explore Collection</a>
            <a href="/about" class="btn btn-outline" style="margin-left: 1rem;">Our Story</a>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="section">
    <div class="container text-center animate-on-scroll">
        <h2 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Our Categories</h2>
        <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto var(--space-6);">Explore our comprehensive range of high-quality fittings and hardware for every need.</p>
        
        <div class="grid">
            <% categories.forEach(category => { %>
                <a href="/products?category=<%= category.slug %>" class="card">
                    <div class="card-img">
                        <!-- Placeholder images will be generated -->
                        <img src="<%= category.image_url %>" alt="<%= category.name %>" onerror="this.src='https://placehold.co/600x400/f8fafc/005b69?text=<%= category.name.replace(/ /g, '+') %>'">
                    </div>
                    <div class="card-content">
                        <h3 class="card-title"><%= category.name %></h3>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</section>

<!-- Featured Products Section -->
<section class="section" style="background-color: var(--border-light);">
    <div class="container animate-on-scroll">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: var(--space-6);">
            <div>
                <h2 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Featured Collection</h2>
                <p style="color: var(--text-secondary);">Discover our most popular and premium products.</p>
            </div>
            <a href="/products" style="display: flex; align-items: center; gap: 0.5rem;">View All <i data-lucide="arrow-right" style="width: 18px;"></i></a>
        </div>

        <div class="grid">
            <% featuredProducts.slice(0, 4).forEach(product => { %>
                <a href="/products/<%= product.slug %>" class="card" style="background: var(--bg-dark);">
                    <div class="card-img">
                        <img src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/600x600/f8fafc/005b69?text=NAXZORA'">
                    </div>
                    <div class="card-content">
                        <span style="font-size: 0.8rem; color: var(--highlight); text-transform: uppercase; letter-spacing: 1px;"><%= product.category_name %></span>
                        <h3 class="card-title" style="margin-top: 0.5rem;"><%= product.name %></h3>
                        <p class="card-desc"><%= product.finish %></p>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</section>

<!-- Stats / CTA -->
<section class="section text-center">
    <div class="container animate-on-scroll">
        <h2 style="font-size: 2.5rem; margin-bottom: var(--space-4);">Built to Last. Designed to Impress.</h2>
        <div style="display: flex; justify-content: center; gap: var(--space-6); margin-bottom: var(--space-6); flex-wrap: wrap;">
            <div>
                <h3 style="font-size: 3rem; color: var(--highlight); margin-bottom: 0;">10+</h3>
                <p style="color: var(--text-secondary);">Years of Excellence</p>
            </div>
            <div>
                <h3 style="font-size: 3rem; color: var(--highlight); margin-bottom: 0;">100%</h3>
                <p style="color: var(--text-secondary);">Quality Tested</p>
            </div>
            <div>
                <h3 style="font-size: 3rem; color: var(--highlight); margin-bottom: 0;">ISO</h3>
                <p style="color: var(--text-secondary);">Certified Products</p>
            </div>
        </div>
        <a href="/contact" class="btn">Contact Us for Bulk Orders</a>
    </div>
</section>

<!-- Brand Mascot Section -->
<section class="section" style="background-color: var(--bg-card);">
    <div class="container animate-on-scroll">
        <div class="grid" style="align-items: center;">
            <div style="text-align: center;">
                <img src="/images/panda.jpeg" alt="NAXZORA Panda Mascot" style="width: 100%; max-width: 300px; height: auto; border-radius: var(--radius-lg); object-fit: contain; border: 4px solid var(--highlight); margin: 0 auto; box-shadow: 0 10px 25px rgba(0,0,0,0.1); background-color: #fff;">
            </div>
            <div>
                <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Meet Our Mascot</h2>
                <p style="color: var(--text-secondary); font-size: 1.1rem; line-height: 1.8;">
                    At NAXZORA, we believe in bringing joy and reliability into every home. Our Panda mascot represents our commitment to being friendly, approachable, and rock-solid in our quality—just like the products we build.
                </p>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
