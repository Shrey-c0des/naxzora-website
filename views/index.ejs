<%- include('partials/header') %>

<!-- Hero Slideshow — Full Screen -->
<section class="hero-slideshow" id="heroSlideshow">
    <!-- Slide 1 -->
    <div class="slide active" style="background: linear-gradient(135deg, #004652 0%, #007a8a 40%, #70a3ac 100%);">
        <div class="container slide-content">
            <h1 class="slide-heading">A Splash of Elegance<br>for Every Home</h1>
        </div>
    </div>
    <!-- Slide 2 -->
    <div class="slide" style="background: linear-gradient(135deg, #005b69 0%, #3a8f9f 50%, #c8e8ec 100%);">
        <div class="container slide-content">
            <h1 class="slide-heading">Precision Engineering<br>for Modern Living.</h1>
        </div>
    </div>
    <!-- Slide 3 -->
    <div class="slide" style="background: linear-gradient(135deg, #003d47 0%, #005b69 40%, #70a3ac 100%);">
        <div class="container slide-content">
            <h1 class="slide-heading">Transform Your Routine<br>into a Relaxing Escape.</h1>
        </div>
    </div>

    <!-- Slide Indicators -->
    <div class="slide-indicators">
        <span class="indicator active" data-slide="0"></span>
        <span class="indicator" data-slide="1"></span>
        <span class="indicator" data-slide="2"></span>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint">
        <i data-lucide="chevron-down" style="width: 24px; height: 24px;"></i>
    </div>
</section>

<!-- Categories Section -->
<section class="section section-cyan">
    <div class="container text-center">
        <span class="pill-badge reveal">Browse By Category</span>
        <h2 class="reveal delay-1" style="font-size: 2.5rem; margin-bottom: 0.5rem;">Our Categories</h2>
        <div class="section-divider reveal delay-2"></div>
        <p class="reveal delay-3" style="color: var(--text-secondary); max-width: 600px; margin: 0 auto var(--space-6);">Explore our comprehensive range of high-quality fittings and hardware.</p>
        <div class="grid">
            <% categories.forEach(category => { %>
                <a href="/products?category=<%= category.slug %>" class="card">
                    <div class="card-img">
                        <img src="<%= category.image_url %>" alt="<%= category.name %>" onerror="this.src='https://placehold.co/600x400/eaf7f8/005b69?text=<%= category.name.replace(/ /g, '+') %>'">
                    </div>
                    <div class="card-content"><h3 class="card-title"><%= category.name %></h3></div>
                </a>
            <% }) %>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="section" style="background: linear-gradient(135deg, #f1f5f9 0%, var(--cyan-bg) 100%);">
    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: var(--space-6);">
            <div>
                <span class="pill-badge reveal">Handpicked For You</span>
                <h2 class="reveal delay-1" style="font-size: 2.5rem; margin-bottom: 0;">Featured Collection</h2>
            </div>
            <a href="/products" class="reveal delay-2" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 500;">View All <i data-lucide="arrow-right" style="width: 18px;"></i></a>
        </div>
        <div class="grid">
            <% featuredProducts.slice(0, 4).forEach(product => { %>
                <a href="/products/<%= product.slug %>" class="card">
                    <div class="card-img">
                        <img src="<%= product.image_url %>" alt="<%= product.name %>" onerror="this.src='https://placehold.co/600x600/eaf7f8/005b69?text=NAXZORA'">
                    </div>
                    <div class="card-content">
                        <span style="font-size: 0.75rem; color: var(--highlight); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600;"><%= product.category_name %></span>
                        <h3 class="card-title" style="margin-top: 0.5rem;"><%= product.name %></h3>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="section section-cyan-dark" style="padding: var(--space-8) 0;">
    <div class="container text-center">
        <span class="pill-badge pill-badge-light reveal">Why Choose NAXZORA</span>
        <h2 class="reveal delay-1" style="font-size: 2.5rem; margin-bottom: var(--space-6);">Built to Last. Designed to Impress.</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-4); margin-bottom: var(--space-6);">
            <div class="stat-card reveal delay-1"><h3>10+</h3><p>Years of Excellence</p></div>
            <div class="stat-card reveal delay-2"><h3>100%</h3><p>Quality Tested</p></div>
            <div class="stat-card reveal delay-3"><h3>ISO</h3><p>Certified Products</p></div>
        </div>
        <a href="/contact" class="btn reveal delay-4" style="background: linear-gradient(135deg, var(--highlight), #e8922c); border-color: var(--highlight);">Contact Us for Bulk Orders</a>
    </div>
</section>

<!-- Mascot -->
<section class="section" style="background: linear-gradient(135deg, #fff 0%, var(--cyan-bg) 100%);">
    <div class="container">
        <div class="grid" style="align-items: center;">
            <div class="reveal-scale" style="text-align: center;">
                <img src="/images/panda.jpeg" alt="NAXZORA Panda Mascot" style="width: 100%; max-width: 320px; height: auto; border-radius: var(--radius-xl); object-fit: contain; border: 4px solid var(--highlight); margin: 0 auto; box-shadow: 0 20px 40px rgba(0,91,105,0.1); background-color: #fff;">
            </div>
            <div>
                <span class="pill-badge reveal">Brand Mascot</span>
                <h2 class="reveal delay-1" style="font-size: 2.5rem; margin-bottom: 1rem;">Meet Our Mascot</h2>
                <div class="section-divider reveal delay-2" style="margin: 0 0 var(--space-3);"></div>
                <p class="reveal delay-3" style="color: var(--text-secondary); font-size: 1.1rem; line-height: 1.9;">At NAXZORA, we believe in bringing joy and reliability into every home. Our Panda mascot represents our commitment to being friendly, approachable, and rock-solid in our quality.</p>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
